{#
  Contact — view data contract (authoritative source: index.php get_data() PHPDoc)
  Child themes may override this view; data is provided by the parent's get_data().
  key                   type     req/opt   default         note
  title                 string   required
  description           string   required
  get_in_touch_heading  string   required
  get_in_touch_description string required
  show_contact_cards    bool     required  true
  contact_address       string   required
  contact_email         string   required
  contact_phone         string   required
  form_heading          string   required
  form_description      string   required  ''
  fluent_form_id        int      required  0               0 = form not configured
  facebook_url          string   required  ''
  twitter_url           string   required  ''
  instagram_url         string   required  ''
  linkedin_url          string   required  ''
  address_html          string   required              pre-formatted address HTML (raw output)
  phone_digits          string   required              digits-only phone for href="tel:"
  can_edit              bool     required              true when current user can edit the page
  edit_link             string   required              admin edit URL for the page
  form_html             string   required  ''            rendered Fluent Form HTML (raw output); empty when form not configured
  form_plugin_missing   bool     required              true when Fluent Forms plugin is not active
#}
<main id="main" class="nera-contact-page bg-gray-50" role="main">

  {# === HERO (inlined from page-hero.php, default variant) === #}
  <section class="py-16 md:py-20 bg-gradient-to-br from-primary via-primary to-primary-dark">
    <div class="max-w-[1200px] mx-auto px-4 lg:px-8">
      <div class="text-center max-w-2xl mx-auto">

        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-on-primary tracking-tight mb-4"
          data-aos="fade-up">
          {{ title|e('html') }}
        </h1>

        {% if description %}
          <p
            class="text-lg md:text-xl font-medium text-on-primary/80"
            data-aos="fade-up"
            data-aos-delay="100">
            {{ description|e('html') }}
          </p>
        {% endif %}

      </div>
    </div>
  </section>

  {# === GRID === #}
  <div class="max-w-7xl mx-auto px-4 lg:px-0 py-12 lg:py-16">
    <div class="gap-8 lg:gap-12 {% if show_contact_cards %}grid grid-cols-1 lg:grid-cols-2{% else %}flex flex-col items-center{% endif %}">

      {# LEFT: contact info (from contact-info.php) #}
      {% if show_contact_cards %}
      <div class="contact-info-section">

        {# Section Heading #}
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-text-primary mb-3">
          {{ get_in_touch_heading|e('html') }}
        </h2>

        <p class="text-primary mb-8">
          {{ get_in_touch_description|e('html') }}
        </p>

        {# Contact Items - Simple List #}
        <div class="space-y-6 mb-8">

          {# Address #}
          {% if contact_address %}
          <div class="flex gap-3 items-start">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings:'FILL' 1">location_on</span>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wide text-text-secondary font-semibold">
                VISIT US
              </div>
              <address class="text-text-primary not-italic">
                {{ address_html|raw }}
              </address>
            </div>
          </div>
          {% endif %}

          {# Email #}
          {% if contact_email %}
          <div class="flex gap-3 items-start">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings:'FILL' 1">mail</span>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wide text-text-secondary font-semibold">
                EMAIL US
              </div>
              <a href="mailto:{{ contact_email|e('html_attr') }}"
                class="text-text-primary hover:text-primary/80 transition-colors break-all">
                {{ contact_email|e('html') }}
              </a>
            </div>
          </div>
          {% endif %}

          {# Phone #}
          {% if contact_phone %}
          <div class="flex gap-3 items-start">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings:'FILL' 1">call</span>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wide text-text-secondary font-semibold">
                CALL US
              </div>
              <a href="tel:{{ phone_digits|e('html_attr') }}"
                class="text-text-primary hover:text-primary/80 transition-colors">
                {{ contact_phone|e('html') }}
              </a>
            </div>
          </div>
          {% endif %}

        </div>

        {# Social Media Icons #}
        {% if facebook_url or twitter_url or instagram_url or linkedin_url %}
        <div class="border-t border-gray-200 pt-6">
          <p class="text-sm text-text-secondary mb-3">
            Follow us
          </p>
          <div class="flex gap-4">

            {% if facebook_url %}
            <a href="{{ facebook_url|e('html_attr') }}" target="_blank" rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center hover:bg-primary/20 transition-colors"
              aria-label="Facebook">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
            </a>
            {% endif %}

            {% if twitter_url %}
            <a href="{{ twitter_url|e('html_attr') }}" target="_blank" rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center hover:bg-primary/20 transition-colors"
              aria-label="Twitter">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" />
              </svg>
            </a>
            {% endif %}

            {% if instagram_url %}
            <a href="{{ instagram_url|e('html_attr') }}" target="_blank" rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center hover:bg-primary/20 transition-colors"
              aria-label="Instagram">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z" />
              </svg>
            </a>
            {% endif %}

            {% if linkedin_url %}
            <a href="{{ linkedin_url|e('html_attr') }}" target="_blank" rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center hover:bg-primary/20 transition-colors"
              aria-label="LinkedIn">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
            {% endif %}

          </div>
        </div>
        {% endif %}

      </div>
      {% endif %}

      {# RIGHT: form (from form-section.php) #}
      <div class="bg-surface rounded-2xl p-6 lg:p-8 shadow-md{% if not show_contact_cards %} w-full max-w-[36rem] min-w-0 shrink{% endif %}">

        {# Form Header #}
        {% if form_heading %}
        <h2 class="text-2xl font-heading font-bold text-text-primary mb-6 text-center">
          {{ form_heading|e('html') }}
        </h2>
        {% endif %}

        {% if form_description %}
        <p class="text-text-secondary mb-6">
          {{ form_description|e('html') }}
        </p>
        {% endif %}

        {# Form Content #}
        {% if form_html %}
          {{ form_html|raw }}
        {% elseif form_plugin_missing %}
          <div class="bg-warning-bg border border-warning-border rounded-lg p-6 text-center">
            <span class="material-symbols-outlined text-warning text-4xl mb-3 block" style="font-variation-settings:'FILL' 1">warning</span>
            <p class="text-warning-text font-semibold mb-2">
              Fluent Forms Plugin Required
            </p>
            <p class="text-warning-text text-sm">
              Please install and activate the Fluent Forms plugin to display the contact form.
            </p>
          </div>
        {% else %}
          <div class="bg-info-bg border border-info-border rounded-lg p-6 text-center">
            <span class="material-symbols-outlined text-primary text-4xl mb-3 block" style="font-variation-settings:'FILL' 1">info</span>
            <p class="text-info-text font-semibold mb-2">
              Contact Form Not Configured
            </p>
            <p class="text-info-text text-sm mb-3">
              Please configure a Fluent Form ID in the page settings to display the contact form.
            </p>
            {% if can_edit %}
            <a href="{{ edit_link|e('html_attr') }}"
              class="inline-flex items-center gap-2 bg-primary text-on-primary px-4 py-2 rounded-lg hover:bg-primary-dark transition-colors text-sm font-medium">
              <span class="material-symbols-outlined text-lg" style="font-variation-settings:'FILL' 1">edit</span>
              Edit Page Settings
            </a>
            {% endif %}
          </div>
        {% endif %}

      </div>

    </div>
  </div>

</main>
