{#
  HowItWorksTransparency — view data contract (authoritative source: index.php get_data() PHPDoc)
  Child themes may override this view; data is provided by the parent's get_data().
  key       type                                                              req/opt   default    note
  title     string                                                            required
  subtitle  string                                                            required
  features  list<{icon:string,title:string,description:string}>               required  3-item default  icon is a Material Symbols ligature string
#}
<section class="py-20 lg:py-32 relative overflow-hidden bg-background-light" aria-labelledby="hiw-trans-heading">
  <div class="max-w-7xl mx-auto px-4 lg:px-0 relative z-10">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 id="hiw-trans-heading" class="font-heading text-4xl lg:text-5xl text-text-primary mb-6"{% if heading_font_style %} style="{{ heading_font_style|raw }}"{% endif %}>
        {{ title }}{% if heading_highlight %} <span style="{{ heading_accent_style|raw }}">{{ heading_highlight }}</span>{% endif %}
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        {{ subtitle }}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {% for feature in features %}
        <div
          class="bg-surface border border-gray-200 p-8 rounded-3xl shadow-sm transition-all duration-500 hover:border-primary/30 hover:shadow-lg hover:-translate-y-1"
          data-aos="fade-up">
          <div class="text-primary mb-6">
            <span class="material-symbols-outlined text-5xl" aria-hidden="true">{{ feature.icon }}</span>
          </div>
          <h3 class="text-xl font-bold mb-4 text-text-primary">
            {{ feature.title }}
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            {{ feature.description }}
          </p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
