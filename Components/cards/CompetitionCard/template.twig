{#
  CompetitionCard — view data contract (authoritative source: index.php get_data() PHPDoc)
  Child themes may override this view; data is provided by the parent's get_data().
  key               type                                                                     req/opt   default   note
  product_id        int                                                                      required  —         WC product ID
  permalink         string                                                                   required  —         product URL
  image_url         string|false|null                                                        required  —         featured image 'large'; null/false = no image
  title             string                                                                   required  —         product display name
  price             string                                                                   required  —         raw WC price
  price_html        string                                                                   required  —         WC-formatted price HTML (|raw)
  accent_color      string                                                                   required  —         hex from primary category or fallback
  badge_text        string                                                                   required  ''        urgency badge label; empty = no badge
  badge_class       string                                                                   required  —         Tailwind gradient classes for badge bg
  is_urgent         bool                                                                     required  —         animate-pulse on badge
  max_tickets       int                                                                      required  —         total ticket capacity
  progress          int                                                                      required  —         sold percentage 0-100
  primary_category  WP_Term|null                                                             required  —         first product_cat; null = uncategorised
  other_cats        list<WP_Term>                                                            required  []        extra category terms for "+N" tooltip
  cat_accent        string                                                                   required  —         hex alias of accent_color
  show_countdown    bool                                                                     required  —         renders Alpine countdown in footer
  end_timestamp_ms  int                                                                      required  0         Unix ms for Alpine countdown
  data_attrs        array{price,end_date,posted_date,popularity,categories:string}           required  —         JS filter data-* values
  x_show            string|null                                                              optional  null      Alpine x-show expression
  extra_attributes  string|null                                                              optional  null      raw HTML attrs on <article>
  sold_tickets      int                                                                      required  —         tickets purchased; used in buy_tickets label
  button_variant    string                                                                   required  'full'    'full'|'compact'|'buy_tickets'
  button_mode       string                                                                   required  'link'    'link'|'ajax' (buy_tickets only)
  card_layout       string|null                                                              optional  classic   'classic'|'portrait' — shop listing only (filter)
  image_aspect_ratio string|null                                                             optional  null      sanitized CSS aspect-ratio — shop listing only (filter)
  NOTE: get_data() returns [] (empty) if the product can't be resolved — view renders nothing in that case (guarded by {% if product_id %}).
#}
{% if product_id %}
{% set card_layout_mode = card_layout|default('classic') %}
<article class="ncs-product-card group min-w-0 transition-all duration-400 ease-out"
  data-price="{{ data_attrs.price }}"
  data-end-date="{{ data_attrs.end_date }}"
  data-posted-date="{{ data_attrs.posted_date }}"
  data-popularity="{{ data_attrs.popularity }}"
  data-categories="{{ data_attrs.categories|e('html_attr') }}"
  {% if extra_attributes %}{{ extra_attributes|raw }}{% endif %}
  {% if x_show %}x-show="{{ x_show }}"{% endif %}
  x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-90"
  x-transition:enter-end="opacity-100 scale-100">

  <!-- Card Inner Wrapper -->
  <div
    class="bg-surface rounded-xl sm:rounded-2xl overflow-hidden shadow-lg border border-gray-100 h-full flex flex-col transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:border-gray-200">

    <!-- Image Container -->
    {% if image_aspect_ratio %}
    <div class="relative overflow-hidden bg-gray-100" style="aspect-ratio: {{ image_aspect_ratio }};">
    {% elseif card_layout_mode == 'portrait' %}
    <div class="relative overflow-hidden bg-gray-100" style="aspect-ratio: 4/5;">
    {% else %}
    <div class="relative aspect-5/3 sm:aspect-4/3 overflow-hidden bg-gray-100">
    {% endif %}

      <!-- Status Badge (Top Left) -->
      {% if badge_text %}
        <div
          class="absolute top-2 left-2 z-10 sm:top-4 sm:left-4 {{ badge_class }} text-white text-[9px] sm:text-[10px] font-extrabold px-2 py-1 sm:px-3 sm:py-1.5 rounded-full uppercase tracking-widest shadow-lg{% if is_urgent %} animate-pulse{% endif %}">
          {{ badge_text }}
        </div>
      {% endif %}

      <!-- Category Badges (Top Right) — hidden for buy_tickets variant -->
      {% if primary_category and button_variant != 'buy_tickets' %}
        <div class="absolute top-2 right-2 z-10 flex max-w-[calc(100%-4.5rem)] items-center gap-1 sm:top-4 sm:right-4 sm:max-w-none sm:gap-1.5">

          <!-- Primary Category Badge -->
          <div
            class="max-w-full truncate px-2 py-1 text-[10px] font-bold rounded-full backdrop-blur-sm border-[1.5px] shadow-sm transform transition-transform hover:scale-105 sm:px-3 sm:py-1.5 sm:text-xs"
            style="background-color: {{ cat_accent }}; color: #fff; border-color: {{ cat_accent }};">
            {{ primary_category.name }}
          </div>

          <!-- "+N" Counter with Tooltip -->
          {% if other_cats|length > 0 %}
            <div class="relative group/tooltip">
              <!-- Counter Badge -->
              <div
                class="shrink-0 px-1.5 py-1 text-[10px] font-bold rounded-full bg-surface/90 backdrop-blur-sm border border-gray-200 text-text-secondary shadow-sm cursor-help hover:bg-surface transition-colors sm:px-2 sm:py-1.5 sm:text-xs">
                +{{ other_cats|length }}
              </div>

              <!-- Tooltip -->
              <div
                class="absolute right-0 top-full mt-2 w-max max-w-[150px] p-2 bg-background-dark/95 backdrop-blur-md text-white text-[10px] font-medium rounded-lg shadow-xl opacity-0 translate-y-2 invisible group-hover/tooltip:opacity-100 group-hover/tooltip:translate-y-0 group-hover/tooltip:visible transition-all duration-200 z-50 flex flex-col gap-1 text-right">
                {% for cat in other_cats %}
                  <span class="block px-1.5 py-0.5 rounded hover:bg-surface/10 transition-colors">
                    {{ cat.name }}
                  </span>
                {% endfor %}
                <!-- Arrow pointer -->
                <div class="absolute -top-1 right-2.5 w-2 h-2 bg-background-dark/95 rotate-45"></div>
              </div>
            </div>
          {% endif %}

        </div>
      {% endif %}

      <!-- Product Image -->
      <a href="{{ permalink }}" class="block w-full h-full">
        {% if image_url %}
          <div
            class="w-full h-full bg-center bg-no-repeat bg-cover transition-transform duration-500 ease-out group-hover:scale-110"
            style="background-image: url('{{ image_url }}');">
          </div>
        {% else %}
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-50 to-gray-100">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
              class="text-gray-300">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <polyline points="21 15 16 10 5 21" />
            </svg>
          </div>
        {% endif %}
      </a>

      <!-- Price Badge (Bottom Right, Glassmorphism) — hidden for buy_tickets variant -->
      {% if button_variant != 'buy_tickets' %}
        <div
          class="absolute bottom-2 right-2 z-10 max-w-[min(100%,11rem)] px-2.5 py-1.5 bg-surface/95 backdrop-blur-md rounded-lg border-[1.5px] border-white/80 shadow-lg sm:bottom-4 sm:right-4 sm:max-w-none sm:rounded-xl sm:px-4 sm:py-2.5"
          style="border-color: {{ accent_color }}30;">
          <div class="text-xs font-extrabold leading-none mb-0.5 sm:text-sm"
            style="color: {{ accent_color }};">
            {{ price_html|raw }}
          </div>
          <div class="text-[9px] font-semibold text-text-secondary uppercase tracking-wide sm:text-[10px]">
            per entry
          </div>
        </div>
      {% endif %}
    </div>

    <!-- Card Content -->
    <div class="p-3 sm:p-5 md:p-6 flex-1 flex flex-col min-w-0">

      <!-- Title -->
      <h3 class="text-sm sm:text-xl font-bold text-text-primary mb-2 sm:mb-4 leading-tight min-h-0 sm:min-h-14 line-clamp-2">
        <a href="{{ permalink }}" class="hover:text-primary transition-colors">
          {{ title }}
        </a>
      </h3>

      <!-- Progress Section -->
      <div class="space-y-2 sm:space-y-3 mb-auto">
        <div class="flex justify-between items-center gap-2">
          {% if button_variant == 'buy_tickets' %}
            <!-- buy_tickets: "X/Y sold" label, only when max_tickets is set -->
            {% if max_tickets %}
              <span class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-text-secondary shrink-0">
                {{ sold_tickets }}/{{ max_tickets }} sold
              </span>
            {% else %}
              <span></span>
            {% endif %}
          {% else %}
            <span class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-text-secondary shrink-0">
              Tickets Sold
            </span>
          {% endif %}
          <span class="text-xs sm:text-sm font-black tabular-nums shrink-0" style="color: {{ accent_color }};">
            {{ progress|default(0) }}%
          </span>
        </div>

        <div class="ncs-product-card__progress-track relative h-[14px] w-full rounded-full overflow-hidden shadow-inner">
          <div class="ncs-product-card__progress-fill h-full rounded-full transition-all duration-500"
            style="width: {{ progress|default(0) }}%; --ncs-product-card-progress-accent: {{ accent_color }};">
          </div>
        </div>
      </div>

      <!-- Footer: Countdown & CTA -->
      <div
        class="flex flex-col items-stretch gap-2 pt-3 mt-3 border-t border-gray-100{% if card_layout_mode == 'portrait' %} sm:pt-5 sm:mt-4{% else %} sm:flex-row sm:items-center sm:justify-between sm:gap-3 sm:pt-5 sm:mt-4{% endif %}">

        {% if button_variant == 'buy_tickets' %}

          <!-- buy_tickets footer: Entry price left, Buy Tickets button right -->
          <div class="text-sm">
            <span class="text-text-secondary">Entry:</span>
            <span class="font-bold text-primary">{{ price_html|raw }}</span>
          </div>

          {% if button_mode == 'ajax' %}
            <button
              class="ncs-product-card__cta add-to-cart-btn inline-flex w-full min-h-[44px] items-center justify-center rounded-xl px-5 py-2.5 text-sm font-bold uppercase tracking-wide bg-primary hover:bg-primary-dark text-white shadow-sm hover:shadow-md transition-all duration-300{% if card_layout_mode != 'portrait' %} sm:w-auto sm:min-h-0 sm:ml-auto{% endif %}"
              data-product-id="{{ product_id }}"
              data-quantity="1">
              Buy Tickets
            </button>
          {% else %}
            <a href="{{ permalink }}"
              class="ncs-product-card__cta inline-flex w-full min-h-[44px] items-center justify-center rounded-xl px-5 py-2.5 text-sm font-bold uppercase tracking-wide bg-primary hover:bg-primary-dark text-white shadow-sm hover:shadow-md transition-all duration-300{% if card_layout_mode != 'portrait' %} sm:w-auto sm:min-h-0 sm:ml-auto{% endif %}">
              Buy Tickets
            </a>
          {% endif %}

        {% else %}

          <!-- Countdown Timer (full and compact variants) -->
          {% if show_countdown %}
            <div
              class="flex w-full items-center gap-1 text-text-secondary{% if card_layout_mode == 'portrait' %} justify-start sm:gap-1.5{% else %} justify-center sm:w-auto sm:justify-start sm:gap-1.5{% endif %}"
              x-data="countdown('{{ end_timestamp_ms }}')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                class="hidden h-3.5 w-3.5 shrink-0 opacity-60 sm:block sm:h-3.5 sm:w-3.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span class="text-[10px] font-bold uppercase leading-snug tabular-nums{% if card_layout_mode == 'portrait' %} text-left sm:text-xs{% else %} text-center sm:text-left sm:text-xs{% endif %}">
                <span x-text="days">00</span>d : <span x-text="hours">00</span>h : <span x-text="minutes">00</span>m : <span x-text="seconds">00</span>s
              </span>
            </div>
          {% endif %}

          {% if button_variant == 'compact' %}
            <!-- compact CTA -->
            <a href="{{ permalink }}"
              class="ncs-product-card__cta inline-flex w-full min-h-[44px] items-center justify-center rounded-lg px-4 py-2 text-xs font-extrabold uppercase tracking-wide transition-all duration-300 bg-primary/5 hover:bg-primary text-primary hover:text-white{% if card_layout_mode != 'portrait' %} sm:w-auto sm:min-h-0 sm:ml-auto{% endif %}">
              ENTER
            </a>
          {% else %}
            <!-- full CTA (default) -->
            <a href="{{ permalink }}"
              class="ncs-product-card__cta group/cta inline-flex w-full min-h-[44px] items-center justify-center gap-1.5 rounded-lg px-3 py-2 text-[11px] font-extrabold uppercase tracking-wide text-white shadow-md transition-all duration-300 hover:shadow-xl hover:scale-105{% if card_layout_mode != 'portrait' %} sm:w-auto sm:min-h-0 sm:px-5 sm:py-2.5 sm:text-xs sm:ml-auto{% else %} sm:px-5 sm:py-2.5 sm:text-xs{% endif %}"
              style="background: linear-gradient(135deg, {{ accent_color }} 0%, {{ accent_color }} 100%);">
              <span>ENTER NOW</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                class="h-3.5 w-3.5 shrink-0 transition-transform group-hover/cta:translate-x-0.5 sm:h-3.5 sm:w-3.5" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
          {% endif %}

        {% endif %}

      </div>

    </div>
  </div>
</article>
{% endif %}
