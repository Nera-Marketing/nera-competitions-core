{#
  ProductTitle — view data contract (authoritative source: index.php get_data() PHPDoc)
  Child themes may override this view; data is provided by the parent's get_data().
  key          type    req/opt   default   note
  name         string  required  ''        product name in "Win a {name}" heading
  is_sold_out  bool    required  false     shows "Sold Out" badge
#}
<div class="flex flex-wrap items-center gap-2 mb-1">
  <h1 class="text-2xl lg:text-3xl font-bold text-text-primary leading-tight">
    Win a {{ name }}
  </h1>
  {% if is_sold_out %}
    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[0.65rem] font-extrabold uppercase tracking-widest bg-gray-200 text-text-secondary">
      Sold Out
    </span>
  {% endif %}
</div>
