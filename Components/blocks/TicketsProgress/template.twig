{#
  TicketsProgress — view data contract (authoritative source: index.php get_data() PHPDoc)
  Child themes may override this view; data is provided by the parent's get_data().
  key                  type    req/opt   default   note
  sold                 int     required  0         raw sold count (only *_formatted rendered)
  max                  int     required  0         raw max count (only *_formatted rendered)
  progress             int     required  0         percentage for progress bar width
  remaining            int     required  0         raw remaining (only *_formatted rendered)
  is_low_stock         bool    required  false     shows "Selling fast" warning
  sold_formatted       string  required  —         number_format of sold; shown in X/Y label
  max_formatted        string  required  —         number_format of max; shown in X/Y label
  remaining_formatted  string  required  —         number_format; shown in low-stock warning
#}
{# TicketsProgress atom #}
{# Variables: sold_formatted, max_formatted, progress, is_low_stock (bool), remaining_formatted #}

<div class="ncs-progress">
  <div class="flex items-center justify-between mb-2">
    <span class="text-sm font-semibold text-text-primary">
      Tickets Sold
    </span>
    <span class="text-sm font-semibold text-text-primary">
      {{ sold_formatted }} / {{ max_formatted }}
    </span>
  </div>

  <div class="ncs-progress__track relative h-[14px] w-full rounded-full overflow-hidden shadow-inner">
    <div class="ncs-progress__fill h-full rounded-full transition-all duration-1000 ease-out" style="width: 0%;"
      data-progress="{{ progress }}"></div>
  </div>

  {% if is_low_stock %}
    <div class="mt-2 flex items-center gap-1 text-warning text-sm">
      <span class="material-symbols-outlined text-base">local_fire_department</span>
      <span>
        Selling fast! Only <strong>{{ remaining_formatted }}</strong> tickets remaining.
      </span>
    </div>
  {% endif %}
</div>
