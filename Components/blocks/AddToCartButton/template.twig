{# AddToCartButton atom #}
{# Variables: product_id, is_expired (bool), label_active, label_ended #}
{# Alpine context (purchaseCard x-data) is provided by the orchestrator's wrapping div #}

<button type="submit" name="add-to-cart" value="{{ product_id }}"
  class="w-full bg-primary text-white text-lg py-4 rounded-xl font-bold shadow-lg shadow-primary/20 hover:bg-primary-dark hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed lty-participate-now-button"
  :class="{'opacity-75 cursor-wait': isSubmitting}"
  :disabled="isSubmitting || {{ is_expired ? 'true' : 'false' }}"
  {% if is_expired %}disabled{% endif %}>

  <template x-if="isSubmitting">
    <span class="material-symbols-outlined animate-spin text-xl">progress_activity</span>
  </template>

  <template x-if="!isSubmitting">
    <span>
      {% if is_expired %}
        {{ label_ended }}
      {% else %}
        {{ label_active }} <span class="material-symbols-outlined relative top-1">arrow_forward</span>
      {% endif %}
    </span>
  </template>
</button>
