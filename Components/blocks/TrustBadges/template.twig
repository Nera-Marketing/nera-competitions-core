{#
  TrustBadges — view data contract (authoritative source: index.php get_data() PHPDoc)
  Child themes may override this view; data is provided by the parent's get_data().
  key     type                              req/opt   default                                                              note
  badges  list<{icon:string,label:string}>  required  [check_circle/'Guaranteed Draw', lock/'Secure Payment']             icon name + label
#}
{# TrustBadges atom #}
{# Variables: badges (array of {icon, label}) #}

<div class="flex items-center justify-center gap-6">
  {% for badge in badges %}
    <div class="flex items-center gap-1.5 text-sm text-text-secondary">
      <span class="material-symbols-outlined text-success text-lg">{{ badge.icon }}</span>
      {{ badge.label }}
    </div>
  {% endfor %}
</div>
