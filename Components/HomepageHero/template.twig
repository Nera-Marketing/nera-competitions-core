<section
  class="ncs-hero hero-section relative py-16 lg:py-24 bg-gradient-to-br from-white via-gray-50 to-secondary overflow-hidden"
  id="hero" data-aos="fade-up" data-aos-duration="600">

  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <div class="order-2 lg:order-1">

        <span class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 text-primary rounded-full text-sm font-semibold mb-6">
          🏆 {{ i18n.badge }}
        </span>

        <h1 class="ncs-hero__title font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-text-primary leading-tight mb-6">
          {{ title }}<br>
          <span class="text-gradient-primary">{{ highlight }}</span>
        </h1>

        <p class="text-lg text-text-secondary leading-relaxed mb-8 max-w-lg">{{ description }}</p>

        <div class="ncs-hero__cta flex flex-wrap gap-4 mb-8">
          <a href="{{ cta.url }}" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-primary text-white font-semibold rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all">
            {{ cta.text }}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a href="{{ secondary.url }}" class="inline-flex items-center gap-2 px-8 py-4 border-2 border-gray-200 text-text-primary font-semibold rounded-xl hover:border-primary hover:text-primary transition-colors">
            {{ secondary.text }}
          </a>
        </div>

      </div>

      <div class="order-1 lg:order-2 relative mb-6 md:mb-0">
        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            {% if image %}
              <img src="{{ image }}" alt="{{ title }}" class="w-full h-auto">
            {% else %}
              <div class="aspect-[4/3] bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
                <span class="text-6xl">🚗</span>
              </div>
            {% endif %}
          </div>

          <div class="absolute bottom-3 right-3 sm:bottom-4 sm:right-4 lg:bottom-8 lg:-right-8 bg-surface rounded-xl sm:rounded-2xl shadow-xl p-2.5 sm:p-4 flex items-center gap-2 sm:gap-3">
            <div class="w-9 h-9 sm:w-12 sm:h-12 rounded-full bg-gradient-primary flex items-center justify-center text-white font-bold text-sm sm:text-base">
              {{ last_winner.initial }}
            </div>
            <div>
              <span class="block text-xs sm:text-sm font-semibold text-text-primary">{{ i18n.last_winner }}</span>
              <span class="block text-[10px] sm:text-xs text-text-secondary">{{ last_winner.name }}</span>
            </div>
            <span class="text-success text-base sm:text-xl">✓</span>
          </div>
        </div>
      </div>

    </div>
  </div>

</section>
